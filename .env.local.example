# ─── Supabase ─────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Your project's public URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Your project's anon/public key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Your project's service role key — NEVER expose this in the browser!
# Used only in server-side code (src/lib/supabase/admin.ts)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
